# ==== App ====
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000
# URL PUBLICA da API (usada no OAuth do Google e exibida em logs).
# Dev: http://localhost:3000  |  Prod: https://api.systemvita.com.br
PUBLIC_BASE_URL=http://localhost:3000

# ==== Dominio (producao) ====
# Estrutura sugerida (Cloudflare -> Coolify):
#   app.systemvita.com.br  -> dashboard (web, porta 3001)
#   api.systemvita.com.br  -> API Fastify (porta 3000): webhook + OAuth
#   systemvita.com.br/www  -> landing (futuro)
# Origens extras permitidas para Server Actions do dashboard (CSV).
# DASHBOARD_ALLOWED_ORIGINS=app.systemvita.com.br

# ==== OpenAI ====
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL_MAIN=gpt-4o-mini
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_AUDIO=whisper-1

# ==== Evolution API ====
# Rodando via docker compose: o Evolution fica em http://evolution:8080 (network interna).
# Rodando em dev local (npm run dev): use http://localhost:8080.
# A INSTANCIA do Evolution (qual conexao WhatsApp usar) NAO esta aqui:
# vem por tenant na tabela `tenants.evolution_instance`. Adicionar tenants via DB.
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=change-me-evolution-key
# OBRIGATORIO e FORTE (min 32 chars, sem placeholders). openssl rand -hex 24
EVOLUTION_WEBHOOK_TOKEN=
# URL interna que o Evolution usa pra alcancar o app no provisionamento automatico.
# Docker compose: http://app:3000/webhook/evolution
EVOLUTION_INTERNAL_WEBHOOK_URL=http://app:3000/webhook/evolution

# ==== Redis ====
REDIS_URL=redis://localhost:6380

# ==== Postgres ====
DATABASE_URL=postgres://ia:ia@localhost:5434/ia_juan
# Limite de conexoes do pool por processo (API e worker tem pools separados).
PG_POOL_MAX=10

# ==== Auth (JWT multi-tenant) ====
# OBRIGATORIO e FORTE (min 32 chars). openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=12h
# Token de servico (backend->backend / SSR do dashboard). OBRIGATORIO e FORTE.
ADMIN_API_TOKEN=
# Admin inicial criado pelo seed (opcional — se vazio, nenhum admin e criado).
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# ==== Google Calendar ====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Dev: http://localhost:3000/...  |  Prod: https://api.systemvita.com.br/oauth/google/callback
# Tem que bater EXATAMENTE com o "Authorized redirect URI" no Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback
# OBRIGATORIO e FORTE — assina o `state` do OAuth (anti-CSRF). openssl rand -hex 32
GOOGLE_OAUTH_STATE_SECRET=
GOOGLE_CALENDAR_ID=primary
# Tokens Google agora vivem 100% no Postgres (tenant_google_tokens). Sem arquivo.

# ==== FSM ====
DEBOUNCE_MS=5000
LEAD_STATE_TTL_SECONDS=604800

# ==== Follow-ups (ms) ====
# 40 min, 24h, 24h (fechamento após 2º follow-up sem resposta)
# 40min no 1o toque dá tempo do lead respirar — não soa robotizado.
FOLLOWUP_1_MS=2400000
FOLLOWUP_2_MS=86400000
FOLLOWUP_CLOSE_MS=86400000

# ==== Modo simulador ====
# true  = IA não envia via Evolution; só grava no banco e aparece na UI do simulador.
#         Útil pra testar a conversa sem conectar WhatsApp real.
# false = IA envia mensagens reais via Evolution para o número do lead.
SIMULATOR_MODE=false

# ==== Prospect (módulo de prospecção) ====
# Tick do scheduler: a cada quanto tempo decide enfileirar próximos envios
PROSPECT_TICK_MS=300000
# Jitter aleatório entre envios (parecer humano)
PROSPECT_JITTER_MS=600000
# Limite diário padrão de novas campanhas
PROSPECT_DEFAULT_RATE_PER_DAY=30
